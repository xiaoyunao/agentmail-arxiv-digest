# Copy this file to .env and fill in local secrets.
# .env is ignored by git.

# Automatic outbound mail backend.
# Agent Mail is used for reading inbound mail; SMTP is used for fully automatic sends.
DAILYARXIV_SMTP_HOST=smtp.example.com
DAILYARXIV_SMTP_PORT=587
DAILYARXIV_SMTP_SECURITY=starttls
DAILYARXIV_SMTP_USERNAME=dailyarxiv@example.com
DAILYARXIV_SMTP_PASSWORD=change-me
DAILYARXIV_SMTP_FROM_EMAIL=dailyarxiv@example.com
DAILYARXIV_SMTP_FROM_NAME=dailyarxiv

# Optional inbound arXiv daily source.
# Defaults are suitable for Gmail and can reuse the SMTP username/password.
DAILYARXIV_IMAP_HOST=imap.gmail.com
DAILYARXIV_IMAP_PORT=993
# DAILYARXIV_IMAP_USERNAME=dailyarxiv@example.com
# DAILYARXIV_IMAP_PASSWORD=change-me
DAILYARXIV_IMAP_MAILBOX=INBOX

# Optional OpenAI settings for future API-backed triage/summaries.
# The current planned workflow uses Codex task export/import instead.
# OPENAI_API_KEY=
# OPENAI_TRIAGE_MODEL=
